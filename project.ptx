<?xml version="1.0" encoding="UTF-8"?>
<!--
  PreTeXt project file
-->
<project ptx-version="2">
  <targets>
    <target name="html" 
      format="html" 
      source="textbook.xml" 
      publication="publication.xml" 
      output-dir="html"/>
    <target name="pdf"
      format="pdf"
      source="textbook.xml"
      publication="publication.xml"
      output-dir="pdf"/>
  </targets>
</project>
